# Copy this file to app/.env.local and fill in the values.
# Never commit .env.local — it contains secrets.

# Supabase — get these from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only. Never expose to the browser.
# Used only in Edge Functions or server-side admin operations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — for email notifications via Edge Function (needed for Session 8)
# Get your key at resend.com
RESEND_API_KEY=re_your_key_here
